APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=lingtour
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

VECTOR_DB_PATH=data/vector_db/scenic_vector_store.json
PGVECTOR_DIMENSION=256
DEFAULT_KNOWLEDGE_BASE_ID=default
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/lingtour

MULTIMODAL_MODEL_PROVIDER=qwen
MULTIMODAL_MODEL_NAME=qwen2.5-omni
MULTIMODAL_MODEL_API_KEY=replace_me

TEXT_MODEL_PROVIDER=deepseek
TEXT_MODEL_NAME=deepseek-v4-flash
TEXT_MODEL_API_KEY=replace_me

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_TIMEOUT_SECONDS=4.5

ASR_PROVIDER=whisper
TTS_PROVIDER=edge

ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
ADMIN_TOKEN_SECRET=replace_with_a_long_random_secret
